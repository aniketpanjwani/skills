  "equations": [
    {
      "eq_id": "main",
      "label": "eq:main",
      "latex": "\\log y_i = \\hat{\\mu} + \\hat{\\alpha} R_i + X_i'\\bar{\\gamma} + \\tilde{\\varepsilon}_i, \\quad \\frac{\\partial^2 \\mathcal{L}}{\\partial \\alpha \\partial \\gamma} = \\mathbb{E}\\left[\\frac{\\partial \\hat{\\varepsilon}_i}{\\partial \\alpha} \\cdot X_i'\\right]",
      "description": "Main estimating equation (second stage)",
      "qa": [
        {
          "question": "What is the main estimating equation?",
          "answer": "log(y_i) = mu + alpha*R_i + X_i'*gamma + epsilon_i"
        }
      ]
    },
    {
      "eq_id": "first-stage",
      "label": "eq:first-stage",
      "latex": "R_i = \\zeta + \\pi M_i + X_i'\\delta + \\nu_i",
      "description": "First-stage equation",
      "qa": [
        {
          "question": "What is the instrument in the first stage?",
          "answer": "M_i (log settler mortality)"
        }
      ]
    },
    {
      "eq_id": "exclusion",
      "label": "eq:exclusion",
      "latex": "\\text{Cov}(M_i, \\varepsilon_i \\mid X_i) = 0",
      "description": "Exclusion restriction",
      "qa": []
    },
    {
      "eq_id": "wald",
      "label": "eq:wald",
      "latex": "\\hat{\\alpha}_{IV} = \\frac{\\text{Cov}(y_i, M_i)}{\\text{Cov}(R_i, M_i)}, \\quad \\mathbb{E}\\left[\\hat{\\alpha}_{IV}\\right] = \\alpha + \\frac{\\mathbb{E}\\left[\\bar{Z}'\\tilde{\\varepsilon}\\right]}{\\mathbb{E}\\left[\\bar{Z}' X\\right]}",
      "description": "Wald estimator for just-identified IV",
      "qa": []
    },
    {
      "eq_id": "reduced-form",
      "label": "eq:reduced-form",
      "latex": "\\log y_i = \\kappa + \\beta M_i + X_i'\\lambda + u_i",
      "description": "Reduced-form equation",
      "qa": []
    },
    {
      "eq_id": "production",
      "label": "eq:production",
      "latex": "Y_i = A_i K_i^{\\alpha} H_i^{1-\\alpha}",
      "description": "Aggregate production function",
      "qa": []
    },
    {
      "eq_id": "institutions-channel",
      "label": "eq:institutions",
      "latex": "A_i = A(R_i, G_i) = \\bar{A} \\cdot R_i^{\\hat{\\theta}} \\cdot G_i^{\\hat{\\phi}}, \\quad \\frac{\\partial^2 A_i}{\\partial R_i \\partial G_i} = \\hat{\\theta}\\hat{\\phi}\\,\\bar{A}\\, R_i^{\\hat{\\theta}-1} G_i^{\\hat{\\phi}-1}",
      "description": "Institutions as determinant of TFP",
      "qa": []
    },
    {
      "eq_id": "settler-model",
      "label": "eq:settler",
      "latex": "R_i = \\begin{cases} R^{extractive} & \\text{if } M_i > \\bar{M} \\\\ R^{inclusive} & \\text{if } M_i \\leq \\bar{M} \\end{cases}",
      "description": "Settler mortality determines institutional type",
      "qa": []
    }
  ],
